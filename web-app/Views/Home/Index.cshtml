@{
    ViewData["Title"] = "Home";
    bool apiHealthy   = ViewBag.ApiHealthy ?? false;
    int  totalPreds   = ViewBag.TotalPredictions ?? 0;
}

<!-- ── Hero ──────────────────────────────────────────────────────────────── -->
<div class="hero-section text-white rounded-4 p-5 mb-5 shadow"
     style="background: linear-gradient(135deg,#1a3a5c 0%,#2E86AB 100%);">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <h1 class="display-5 fw-bold mb-3">
                🛒 Shopping Channel Preference Predictor
            </h1>
            <p class="lead mb-4">
                An ML-powered tool that classifies customers into
                <strong>Online</strong>, <strong>In-Store</strong>, or
                <strong>Hybrid</strong> shopping segments using 24 behavioural,
                demographic, and attitudinal features.
            </p>
            <a asp-controller="Prediction" asp-action="Predict"
               class="btn btn-warning btn-lg fw-bold shadow me-3">
                <i class="bi bi-lightning-charge-fill me-2"></i>Make a Prediction
            </a>
            <a asp-controller="Prediction" asp-action="History"
               class="btn btn-outline-light btn-lg">
                <i class="bi bi-clock-history me-2"></i>View History
            </a>
        </div>
        <div class="col-lg-4 text-center d-none d-lg-block">
            <span style="font-size:8rem; line-height:1;">🎯</span>
        </div>
    </div>
</div>

<!-- ── Status Cards ───────────────────────────────────────────────────────── -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="display-4 mb-2">💻</div>
            <h5 class="fw-bold">Online Shoppers</h5>
            <p class="text-muted small">
                High digital engagement, frequent online orders,
                strong trust in digital payments.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="display-4 mb-2">🏪</div>
            <h5 class="fw-bold">In-Store Shoppers</h5>
            <p class="text-muted small">
                Prefer tactile experience, frequent store visits,
                lower technology comfort scores.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="display-4 mb-2">🔄</div>
            <h5 class="fw-bold">Hybrid Shoppers</h5>
            <p class="text-muted small">
                Balanced channel usage, omni-channel loyalty,
                high lifetime value segment.
            </p>
        </div>
    </div>
</div>

<!-- ── API & Stats ────────────────────────────────────────────────────────── -->
<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                @if (apiHealthy)
                {
                    <span class="badge bg-success fs-6 px-3 py-2">
                        <i class="bi bi-check-circle-fill me-1"></i> API Online
                    </span>
                    <span class="text-muted">
                        FastAPI prediction service is reachable and healthy.
                    </span>
                }
                else
                {
                    <span class="badge bg-danger fs-6 px-3 py-2">
                        <i class="bi bi-x-circle-fill me-1"></i> API Offline
                    </span>
                    <span class="text-muted">
                        Start the FastAPI service:
                        <code>uvicorn app.main:app --reload</code>
                    </span>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <span class="display-6 fw-bold text-primary">@totalPreds</span>
                <span class="text-muted">
                    total predictions saved in this session's database.
                </span>
            </div>
        </div>
    </div>
</div>

<!-- ── Project Details ────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white fw-bold">
        <i class="bi bi-info-circle me-2"></i>Project Overview
    </div>
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <h6 class="fw-bold">📊 Dataset</h6>
                <ul class="list-unstyled small text-muted">
                    <li>Source: Kaggle – Online vs In-Store Shopping Behaviour</li>
                    <li>Records: 11,789 customers</li>
                    <li>Features: 26 (24 inputs + target)</li>
                    <li>Classes: Online, Store, Hybrid</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h6 class="fw-bold">🤖 Model Performance</h6>
                <ul class="list-unstyled small text-muted">
                    <li>Final Model: Logistic Regression (Tuned)</li>
                    <li>Accuracy: ~98.2%</li>
                    <li>Weighted F1-Score: ~0.980</li>
                    <li>Tuning: 5-Fold Stratified Cross-Validation</li>
                </ul>
            </div>
        </div>
    </div>
</div>
