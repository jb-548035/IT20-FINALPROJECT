@model ShoppingPredictor.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="alert alert-danger shadow">
            <h2><i class="bi bi-exclamation-triangle-fill me-2"></i>An Error Occurred</h2>
            <p class="mb-1">@Model.Message</p>
            @if (Model.ShowRequestId)
            {
                <small class="text-muted">Request ID: <code>@Model.RequestId</code></small>
            }
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-house me-1"></i>Return Home
        </a>
    </div>
</div>
