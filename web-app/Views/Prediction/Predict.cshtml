@model ShoppingPredictor.Models.CustomerInputModel
@{
    ViewData["Title"] = "Predict";
}

<h2 class="fw-bold mb-1">
    <i class="bi bi-lightning-charge-fill text-warning me-2"></i>Predict Shopping Preference
</h2>
<p class="text-muted mb-4">
    Fill in the customer's profile and click <strong>Predict</strong> to classify their
    preferred shopping channel.
</p>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <asp-validation-summary model-only="true" />
    </div>
}

<form asp-action="Predict" method="post" id="predictionForm">
    @Html.AntiForgeryToken()

    <!-- ── Section 1: Demographics ─────────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-person-fill me-2"></i>1. Demographic Information
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="Age" class="form-label fw-semibold"></label>
                    <input asp-for="Age" class="form-control" type="number" step="1" />
                    <span asp-validation-for="Age" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="MonthlyIncome" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">₹</span>
                        <input asp-for="MonthlyIncome" class="form-control" type="number" step="500" />
                    </div>
                    <span asp-validation-for="MonthlyIncome" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Gender" class="form-label fw-semibold"></label>
                    <select asp-for="Gender" class="form-select">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="CityTier" class="form-label fw-semibold"></label>
                    <select asp-for="CityTier" class="form-select">
                        <option value="Tier 1">Tier 1 (Metro)</option>
                        <option value="Tier 2">Tier 2 (Mid-size)</option>
                        <option value="Tier 3">Tier 3 (Small)</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Section 2: Digital Behavior ─────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-info text-white fw-bold">
            <i class="bi bi-phone-fill me-2"></i>2. Digital Behaviour
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="DailyInternetHours" class="form-label fw-semibold"></label>
                    <input asp-for="DailyInternetHours" type="range" class="form-range"
                           min="0" max="24" step="0.5"
                           oninput="document.getElementById('lblInternet').textContent=this.value" />
                    <span class="text-muted small">Value: <strong id="lblInternet">@Model.DailyInternetHours</strong> hrs</span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SocialMediaHours" class="form-label fw-semibold"></label>
                    <input asp-for="SocialMediaHours" type="range" class="form-range"
                           min="0" max="12" step="0.5"
                           oninput="document.getElementById('lblSocial').textContent=this.value" />
                    <span class="text-muted small">Value: <strong id="lblSocial">@Model.SocialMediaHours</strong> hrs</span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SmartphoneUsageYears" class="form-label fw-semibold"></label>
                    <input asp-for="SmartphoneUsageYears" class="form-control" type="number" step="0.5" min="0" max="20" />
                </div>
                <div class="col-md-4">
                    <label asp-for="OnlinePaymentTrustScore" class="form-label fw-semibold"></label>
                    <input asp-for="OnlinePaymentTrustScore" type="range" class="form-range"
                           min="1" max="10" step="1"
                           oninput="document.getElementById('lblTrust').textContent=this.value" />
                    <span class="text-muted small">Score: <strong id="lblTrust">@Model.OnlinePaymentTrustScore</strong>/10</span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TechSavvyScore" class="form-label fw-semibold"></label>
                    <input asp-for="TechSavvyScore" type="range" class="form-range"
                           min="1" max="10" step="1"
                           oninput="document.getElementById('lblTech').textContent=this.value" />
                    <span class="text-muted small">Score: <strong id="lblTech">@Model.TechSavvyScore</strong>/10</span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MonthlyOnlineOrders" class="form-label fw-semibold"></label>
                    <input asp-for="MonthlyOnlineOrders" class="form-control" type="number" min="0" max="100" />
                </div>
            </div>
        </div>
    </div>

    <!-- ── Section 3: Shopping Behaviour ───────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-warning text-dark fw-bold">
            <i class="bi bi-bag-fill me-2"></i>3. Shopping Behaviour
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="MonthlyStoreVisits" class="form-label fw-semibold"></label>
                    <input asp-for="MonthlyStoreVisits" class="form-control" type="number" min="0" max="50" />
                </div>
                <div class="col-md-3">
                    <label asp-for="AvgOnlineSpend" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">₹</span>
                        <input asp-for="AvgOnlineSpend" class="form-control" type="number" step="100" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label asp-for="AvgStoreSpend" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">₹</span>
                        <input asp-for="AvgStoreSpend" class="form-control" type="number" step="100" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label asp-for="AvgDeliveryDays" class="form-label fw-semibold"></label>
                    <input asp-for="AvgDeliveryDays" class="form-control" type="number" step="0.5" min="0" max="30" />
                </div>
                @* Sliders for sensitivity scores *@
                @foreach (var (prop, id, label) in new[]
                {
                    ("DiscountSensitivity",     "disc",  "Discount Sensitivity"),
                    ("ReturnFrequency",         "ret",   "Return Frequency"),
                    ("DeliveryFeeSensitivity",  "delfee","Delivery Fee Sensitivity"),
                })
                {
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">@label (1–10)</label>
                        <input name="@prop" id="slider_@id" type="range" class="form-range"
                               min="1" max="10" step="1" value="5"
                               oninput="document.getElementById('lbl_@id').textContent=this.value" />
                        <span class="text-muted small">Score: <strong id="lbl_@id">5</strong>/10</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Section 4: Attitudinal Factors ──────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-success text-white fw-bold">
            <i class="bi bi-brain me-2"></i>4. Attitudinal Factors
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                @foreach (var (prop, id, label, defVal) in new[]
                {
                    ("FreeReturnImportance",       "fri",  "Free Return Importance",        8),
                    ("ProductAvailabilityOnline",  "pao",  "Online Product Availability",   8),
                    ("ImpulseBuyingScore",         "imp",  "Impulse Buying Score",          6),
                    ("NeedTouchFeelScore",         "ntf",  "Need Touch / Feel Score",       3),
                    ("BrandLoyaltyScore",          "bls",  "Brand Loyalty Score",           5),
                    ("EnvironmentalAwareness",     "env",  "Environmental Awareness",       7),
                    ("TimePressureLevel",          "tpl",  "Time Pressure Level",           8),
                })
                {
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">@label (1–10)</label>
                        <input name="@prop" id="slider_@id" type="range" class="form-range"
                               min="1" max="10" step="1" value="@defVal"
                               oninput="document.getElementById('lbl_@id').textContent=this.value" />
                        <span class="text-muted small">Score: <strong id="lbl_@id">@defVal</strong>/10</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Submit ────────────────────────────────────────────────────────── -->
    <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-4">
        <button type="reset" class="btn btn-outline-secondary btn-lg px-4">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
        </button>
        <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold" id="btnSubmit">
            <i class="bi bi-lightning-charge-fill me-2"></i>Predict Shopping Preference
        </button>
    </div>
</form>

@section Scripts {
<script>
    // Show loading spinner when form is submitted
    document.getElementById('predictionForm').addEventListener('submit', function () {
        const btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Predicting...';
    });
</script>
}
